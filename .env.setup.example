# Supabase Management API — personal access token
SUPABASE_ACCESS_TOKEN=your-supabase-pat

# Supabase organization slug
SUPABASE_ORG_SLUG=your-org-slug

# Supabase project reference ID
SUPABASE_PROJECT_REF=your-project-ref

# Database password (set during project creation)
SUPABASE_DB_PASSWORD=your-db-password

# Manager email for RLS policies
MANAGER_EMAIL=manager@example.com

# Deployment URLs for Supabase auth redirect config
GITHUB_PAGES_URL=https://your-username.github.io/repo-name
LOCAL_DEV_URL=http://localhost:5173
