# Supabase project URL (publishable)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (publishable — safe to commit)
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# Base path for GitHub Pages deployment (/ for local dev)
VITE_BASE_PATH=/

# Manager email for admin login
VITE_MANAGER_EMAIL=manager@example.com
